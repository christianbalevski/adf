{
  "name": "adf-studio",
  "version": "0.2.0",
  "description": "Agent Document Format - The document is the agent boundary",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "dev:2": "ADF_INSTANCE=2 electron-vite dev",
    "dev:3": "ADF_INSTANCE=3 electron-vite dev",
    "dev:4": "ADF_INSTANCE=4 electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "electron-vite build && electron-builder",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "node scripts/rebuild-for-node.mjs && vitest run",
    "test:watch": "node scripts/rebuild-for-node.mjs && vitest",
    "bench": "RUN_BENCH=1 NODE_ENV=production node scripts/rebuild-for-node.mjs && RUN_BENCH=1 NODE_ENV=production vitest run tests/perf/stress-harness.test.ts --reporter=verbose",
    "daemon": "node scripts/rebuild-for-node.mjs && npx tsx src/main/daemon/index.ts",
    "adf": "npx tsx src/main/cli/index.ts",
    "stress:runtime": "node scripts/stress-runtime.mjs",
    "postinstall": "electron-rebuild -f -o better-sqlite3"
  },
  "keywords": [
    "agent",
    "document",
    "adf",
    "electron"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.37",
    "@ai-sdk/openai": "^3.0.25",
    "@ai-sdk/openai-compatible": "^2.0.27",
    "@anthropic-ai/tokenizer": "^0.0.4",
    "@codemirror/autocomplete": "^6.20.0",
    "@codemirror/commands": "^6.10.2",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.4",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/lang-yaml": "^6.1.2",
    "@codemirror/language": "^6.12.1",
    "@codemirror/lint": "^6.9.4",
    "@codemirror/search": "^6.6.0",
    "@codemirror/state": "^6.5.4",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.39.15",
    "@dagrejs/dagre": "^2.0.4",
    "@fastify/websocket": "^11.2.0",
    "@floating-ui/dom": "^1.7.5",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@tanstack/react-virtual": "^3.13.18",
    "@tiptap/extension-image": "^3.20.0",
    "@tiptap/extension-placeholder": "^3.18.0",
    "@tiptap/extension-table": "^3.18.0",
    "@tiptap/markdown": "^3.18.0",
    "@tiptap/pm": "^3.18.0",
    "@tiptap/react": "^3.18.0",
    "@tiptap/starter-kit": "^3.18.0",
    "@xyflow/react": "^12.10.0",
    "ai": "^6.0.73",
    "ai-sdk-provider-gemini-cli": "^2.0.1",
    "better-sqlite3": "^12.6.2",
    "bonjour-service": "^1.3.0",
    "chokidar": "^5.0.0",
    "codemirror": "^6.0.2",
    "cron-parser": "^5.5.0",
    "dompurify": "^3.3.3",
