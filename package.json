    "grammy": "^1.40.0",
    "html-to-text": "^9.0.5",
    "imapflow": "^1.2.16",
    "mailparser": "^3.9.4",
    "marked": "^17.0.1",
    "nanoid": "^5.1.6",
    "nodemailer": "^8.0.3",
    "picomatch": "^4.0.3",
    "react": "^19.2.4",
